---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const patterns = await getCollection("patterns");
patterns.sort((a, b) => a.id.localeCompare(b.id));

function formatName(id: string): string {
    return id
        .replace(/^\d+[-_]/, "")
        .replace(/[-_]/g, " ")
        .replace(/\b\w/g, (c) => c.toUpperCase());
}
---

<Layout title="meta-starter">
    <div class="max-w-2xl mx-auto px-6 py-16">
        <header class="mb-12">
            <h1 class="text-3xl font-bold tracking-tight mb-3">Meta Starter</h1>
            <p class="text-gray-500 text-lg leading-relaxed">
                A curated inventory of patterns for building web, mobile, and
                desktop apps with AI assistance. Start with everything, remove
                what you don't need.
            </p>
        </header>

        <section>
            <h2
                class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4"
            >
                Patterns
            </h2>
            <ul class="space-y-0.5">
                {
                    patterns.map((pattern) => (
                        <li>
                            <a
                                href={`/patterns/${pattern.id}`}
                                class="flex items-center justify-between py-2.5 px-3 -mx-3 rounded-md hover:bg-gray-50 text-gray-700 hover:text-gray-900 transition-colors group"
                            >
                                <span class="font-medium">
                                    {formatName(pattern.id)}
                                </span>
                                <span class="text-gray-300 group-hover:text-gray-400 transition-colors text-sm">
                                    →
                                </span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>

        <footer class="mt-16 pt-8 border-t border-gray-100">
            <a
                href="https://github.com/wzulfikar/meta-starter"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-400 hover:text-gray-600 transition-colors"
            >
                github.com/wzulfikar/meta-starter
            </a>
        </footer>
    </div>
</Layout>
